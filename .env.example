# Copy this file to .env and fill in your key. The .env file is gitignored.
# Real values exported in the environment always override this file.
#
# The CLI runs on the Korai P2P inference network. Set KORAI_API_KEY, or run
# against a local/LAN worker with --local (no key required).

KORAI_API_KEY=sk-korai-...
# Optional: override the orchestrator URL (defaults to https://korai-eu.fly.dev).
# KORAI_BASE_URL=http://localhost:8080
