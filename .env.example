# Copy this file to .env and fill in your key. The .env file is gitignored.
# Real values exported in the environment always override this file.
#
# The CLI runs on the Korai P2P inference network. Set KORAI_API_KEY, or run
# against a local/LAN worker with --local (no key required).

# --- Korai backend (preferred) ---
# Two ways to authenticate the networked backend:
#   1. `korai login` — cross-device login from a browser (the `gh auth login`
#      pattern). Stores a rotating, revocable token in ~/.korai/auth.json, which
#      takes precedence over KORAI_API_KEY. Use `korai login --device` when
#      headless (SSH). `korai logout` revokes it.
#   2. KORAI_API_KEY — a static key, for CI / non-interactive use.
KORAI_API_KEY=sk-korai-...
# Optional: override the orchestrator (API) URL (defaults to https://korai-eu.fly.dev).
# The /oauth/* login endpoints live here too.
# KORAI_BASE_URL=http://localhost:8080
# Optional: override the web app origin opened in the browser during `korai login`
# (the human consent page; defaults to https://korai.one). For local dev:
# KORAI_WEB_URL=http://localhost:3030
